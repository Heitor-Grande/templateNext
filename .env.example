TEMPLATE_AUTH_EMAIL="admin@template.com"
TEMPLATE_AUTH_PASSWORD="admin123"

# Variavel para definir o ambiente (DEV ou PROD)
AMBIENTE="DEV"

# Segredo usado para assinar o JWT de sessao.
JWT_SECRET="altere-este-segredo-em-producao"

# Validade do JWT de sessao. Ex: 7d, 24h, 3600.
JWT_VALIDADE="7d"

# Validade do cookie de sessao em segundos. 604800 = 7 dias.
MAXAGE_COOKIE=604800

# Use DATABASE_URL ou as variaveis POSTGRES_* abaixo.
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DATABASE="template"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_SSL=false
