# Variável para definir o ambiente (DEV ou PROD)
AMBIENTE="DEV"

# Segredo usado para assinar o JWT de sessao.
JWT_SECRET="XXX-YYY-ZZZ"

# Validade do JWT de sessao. Ex: 7d, 24h, 3600.
JWT_VALIDADE="7d"

# Validade do JWT temporário de recuperação de senha. Ex: 15m, 900.
JWT_REC_SENHA_VALIDADE="15m"

# OBSERVAÇÃO: o tempo do JWT deve ser igual ao tempo do cookie de sessão para evitar problemas de expiração.

# Validade do cookie de sessao em segundos. 604800 = 7 dias.
MAXAGE_COOKIE=604800

# Credenciais do banco de dados PostgreSQL.
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DATABASE="template"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="grande123"
POSTGRES_SSL=false

# Configurações SMTP usadas pelo envio de e-mails transacionais.
SMTP_HOST="smtp.exemplo.com"
SMTP_PORT=587
SMTP_USER="usuario-smtp"
SMTP_PASS="senha-smtp"
SMTP_FROM="Template App <nao-responder@exemplo.com>"

# anotação de login admin
# email: admin.dev@email.com
# senha: dev@admin#2026template
